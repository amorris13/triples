<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="fill_parent"
  android:layout_height="fill_parent"
  android:background="?attr/colorSurface"
  android:clipChildren="false"
  android:clipToPadding="false">

  <ViewStub
    android:id="@+id/status_bar"
    android:inflatedId="@+id/status_bar"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true" />

  <View
    android:id="@+id/bottom_separator"
    android:layout_width="fill_parent"
    android:layout_height="1sp"
    android:layout_above="@id/status_bar"
    android:background="@color/color_separator" />

  <ViewAnimator
    android:id="@+id/view_switcher"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:inAnimation="@android:anim/fade_in"
    android:outAnimation="@android:anim/fade_out"
    android:layout_above="@id/bottom_separator"
    android:layout_alignParentTop="true"
    android:measureAllChildren="false"
    android:clipChildren="false"
    android:clipToPadding="false">

    <include
      android:layout_width="fill_parent"
      android:layout_height="fill_parent"
      layout="@layout/cards" />

    <TextView
      android:id="@+id/paused"
      android:layout_width="fill_parent"
      android:layout_height="fill_parent"
      android:gravity="center"
      android:text="@string/paused"
      android:textColor="@color/color_separator"
      android:textSize="@dimen/game_paused_text_size" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/game_completed"
          android:textColor="@color/color_text_primary"
          android:textSize="@dimen/game_paused_text_size"
          />

      <TextView
          android:id="@+id/game_output"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textSize="24sp"
          android:textStyle="bold"
          android:layout_marginTop="8dp"
          android:layout_marginBottom="8dp"/>

      <GridLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:columnCount="2"
          android:rowCount="2"
          android:paddingBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fastest_triple"
            android:paddingRight="10dp"/>
        <TextView
            android:id="@+id/fastest_triple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:paddingRight="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/slowest_triple"
            android:paddingRight="10dp"/>
        <TextView
            android:id="@+id/slowest_triple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:paddingRight="4dp"/>
      </GridLayout>

      <com.antsapps.triples.stats.TimelineView
          android:id="@+id/timeline"
          android:layout_width="match_parent"
          android:layout_height="50dp"
          android:layout_marginLeft="20dp"
          android:layout_marginRight="20dp"
          android:layout_marginTop="10dp"
          android:layout_marginBottom="10dp"/>

      <TextView
          android:id="@+id/performance_description"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:gravity="center"
          android:textColor="@color/color_text_primary"
          android:textSize="16sp"
          android:padding="10dp"/>

      <LinearLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rate_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rate_app"
            android:textAllCaps="true"
            android:onClick="rateApp"
            android:layout_marginRight="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/statistics_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/statistics"
            android:textAllCaps="true"
            android:onClick="showStatistics"
            android:layout_marginRight="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/new_game_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/new_game"
            android:textAllCaps="true"
            android:onClick="newGame"/>

      </LinearLayout>

    </LinearLayout>
  </ViewAnimator>

</RelativeLayout>