<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1,2,3">

            <!-- Cards Row -->
            <TableRow
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <View />

                <com.antsapps.triples.views.SingleScaledCardView
                    android:id="@+id/card_icon_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp" />

                <com.antsapps.triples.views.SingleScaledCardView
                    android:id="@+id/card_icon_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp" />

                <com.antsapps.triples.views.SingleScaledCardView
                    android:id="@+id/card_icon_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp" />

                <View />
            </TableRow>

            <!-- Number Row -->
            <TableRow android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    android:text="@string/number"
                    android:textSize="12sp" />

                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_0"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_1"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_2"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/number_conclusion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:textSize="11sp" />

                    <ImageView
                        android:id="@+id/number_tick_cross"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="centerInside" />
                </LinearLayout>
            </TableRow>

            <!-- Shape Row -->
            <TableRow android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    android:text="@string/shape"
                    android:textSize="12sp" />

                <com.antsapps.triples.views.ShapeIconView
                    android:id="@+id/shape_icon_0"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.ShapeIconView
                    android:id="@+id/shape_icon_1"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.ShapeIconView
                    android:id="@+id/shape_icon_2"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/shape_conclusion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:textSize="11sp" />

                    <ImageView
                        android:id="@+id/shape_tick_cross"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="centerInside" />
                </LinearLayout>
            </TableRow>

            <!-- Pattern Row -->
            <TableRow android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    android:text="@string/pattern"
                    android:textSize="12sp" />

                <com.antsapps.triples.views.PatternIconView
                    android:id="@+id/pattern_icon_0"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.PatternIconView
                    android:id="@+id/pattern_icon_1"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.PatternIconView
                    android:id="@+id/pattern_icon_2"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/pattern_conclusion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:textSize="11sp" />

                    <ImageView
                        android:id="@+id/pattern_tick_cross"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="centerInside" />
                </LinearLayout>
            </TableRow>

            <!-- Color Row -->
            <TableRow android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    android:text="@string/colour"
                    android:textSize="12sp" />

                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_0"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_1"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_2"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/color_conclusion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:textSize="11sp" />

                    <ImageView
                        android:id="@+id/color_tick_cross"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="centerInside" />
                </LinearLayout>
            </TableRow>
        </TableLayout>
    </LinearLayout>
</merge>
