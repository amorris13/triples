<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <ImageView
            android:id="@+id/dismiss_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"
            android:padding="4dp"
            android:src="@drawable/ic_cross"
            app:tint="@color/color_text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete" />

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1,2,3">

            <TableRow android:gravity="center_vertical" android:layout_height="52dp">
                <View android:layout_width="80dp" android:layout_height="0dp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="2dp">
                    <com.antsapps.triples.cardsview.CardView
                        android:id="@+id/card_0"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center" />
                </FrameLayout>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="2dp">
                    <com.antsapps.triples.cardsview.CardView
                        android:id="@+id/card_1"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center" />
                </FrameLayout>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="2dp">
                    <com.antsapps.triples.cardsview.CardView
                        android:id="@+id/card_2"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center" />
                </FrameLayout>
                <View android:layout_width="24dp" android:layout_height="0dp" />
            </TableRow>

            <!-- Number Row -->
            <TableRow android:gravity="center_vertical" android:layout_height="48dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/number"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <ImageView
                    android:id="@+id/number_result"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
            </TableRow>

            <!-- Shape Row -->
            <TableRow android:gravity="center_vertical" android:layout_height="48dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/shape"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
                <com.antsapps.triples.cardsview.ShapeIconView
                    android:id="@+id/shape_icon_0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.cardsview.ShapeIconView
                    android:id="@+id/shape_icon_1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.cardsview.ShapeIconView
                    android:id="@+id/shape_icon_2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <ImageView
                    android:id="@+id/shape_result"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
            </TableRow>

            <!-- Pattern Row -->
            <TableRow android:gravity="center_vertical" android:layout_height="48dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pattern"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
                <com.antsapps.triples.cardsview.PatternIconView
                    android:id="@+id/pattern_icon_0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.cardsview.PatternIconView
                    android:id="@+id/pattern_icon_1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.cardsview.PatternIconView
                    android:id="@+id/pattern_icon_2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <ImageView
                    android:id="@+id/pattern_result"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
            </TableRow>

            <!-- Color Row -->
            <TableRow android:gravity="center_vertical" android:layout_height="48dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/colour"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />
                <ImageView
                    android:id="@+id/color_result"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
            </TableRow>
        </TableLayout>
    </RelativeLayout>
</merge>
