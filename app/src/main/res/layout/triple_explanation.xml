<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="4">

        <TableRow android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <View android:layout_width="60dp" android:layout_height="0dp" />
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp">
                <com.antsapps.triples.cardsview.CardView
                    android:id="@+id/card_0"
                    android:layout_width="96dp"
                    android:layout_height="60dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp">
                <com.antsapps.triples.cardsview.CardView
                    android:id="@+id/card_1"
                    android:layout_width="96dp"
                    android:layout_height="60dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="30dp">
                <com.antsapps.triples.cardsview.CardView
                    android:id="@+id/card_2"
                    android:layout_width="96dp"
                    android:layout_height="60dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <View android:layout_width="wrap_content" android:layout_height="0dp" />
            <View android:layout_width="16dp" android:layout_height="0dp" />
            </TableRow>

            <!-- Number Row -->
            <TableRow android:gravity="center_vertical">
                <TextView
                android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/number"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_0"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.views.NumberIconView
                    android:id="@+id/number_icon_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
                <TextView
                    android:id="@+id/number_conclusion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:gravity="right"
                    android:paddingRight="4dp" />
                <ImageView
                    android:id="@+id/number_result"
                    android:layout_width="16dp"
                    android:layout_height="16dp" />
            </TableRow>

            <!-- Shape Row -->
            <TableRow android:gravity="center_vertical">
                <TextView
                android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/shape"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.cardsview.ShapeIconView
                    android:id="@+id/shape_icon_0"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.cardsview.ShapeIconView
                    android:id="@+id/shape_icon_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.cardsview.ShapeIconView
                    android:id="@+id/shape_icon_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
                <TextView
                    android:id="@+id/shape_conclusion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:gravity="right"
                    android:paddingRight="4dp" />
                <ImageView
                    android:id="@+id/shape_result"
                    android:layout_width="16dp"
                    android:layout_height="16dp" />
            </TableRow>

            <!-- Pattern Row -->
            <TableRow android:gravity="center_vertical">
                <TextView
                android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pattern"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.cardsview.PatternIconView
                    android:id="@+id/pattern_icon_0"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.cardsview.PatternIconView
                    android:id="@+id/pattern_icon_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.cardsview.PatternIconView
                    android:id="@+id/pattern_icon_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
                <TextView
                    android:id="@+id/pattern_conclusion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:gravity="right"
                    android:paddingRight="4dp" />
                <ImageView
                    android:id="@+id/pattern_result"
                    android:layout_width="16dp"
                    android:layout_height="16dp" />
            </TableRow>

            <!-- Color Row -->
            <TableRow android:gravity="center_vertical">
                <TextView
                android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/colour"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:paddingRight="4dp" />
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_0"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
            <FrameLayout android:layout_width="48dp" android:layout_height="32dp">
                <com.antsapps.triples.views.ColorIconView
                    android:id="@+id/color_icon_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_gravity="center" />
            </FrameLayout>
                <TextView
                    android:id="@+id/color_conclusion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/color_text_primary"
                    android:gravity="right"
                    android:paddingRight="4dp" />
                <ImageView
                    android:id="@+id/color_result"
                    android:layout_width="16dp"
                    android:layout_height="16dp" />
            </TableRow>
        </TableLayout>
    </LinearLayout>
</merge>
