<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="@dimen/stats_side_padding"
    android:paddingRight="@dimen/stats_side_padding"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="DISTRIBUTION"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.github.mikephil.charting.charts.BarChart
        android:id="@+id/histogram_chart"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="TIME SERIES"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.github.mikephil.charting.charts.ScatterChart
        android:id="@+id/scatter_chart"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <View
        android:layout_width="fill_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUMMARY"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Games"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/number_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Average"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/average"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERCENTILES"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">

                <TableRow>
                    <TextView android:text="25th" android:paddingRight="16dp" android:textSize="12sp" />
                    <TextView android:id="@+id/p25" android:textStyle="bold" />
                </TableRow>
                <TableRow>
                    <TextView android:text="50th" android:paddingRight="16dp" android:textSize="12sp" />
                    <TextView android:id="@+id/p50" android:textStyle="bold" />
                </TableRow>
                <TableRow>
                    <TextView android:text="75th" android:paddingRight="16dp" android:textSize="12sp" />
                    <TextView android:id="@+id/p75" android:textStyle="bold" />
                </TableRow>
                <TableRow>
                    <TextView android:text="95th" android:paddingRight="16dp" android:textSize="12sp" />
                    <TextView android:id="@+id/p95" android:textStyle="bold" />
                </TableRow>
                <TableRow>
                    <TextView android:text="Max" android:paddingRight="16dp" android:textSize="12sp" />
                    <LinearLayout android:orientation="vertical">
                        <TextView android:id="@+id/best" android:textStyle="bold" />
                        <TextView android:id="@+id/best_date" android:textSize="10sp" />
                    </LinearLayout>
                </TableRow>
            </TableLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
