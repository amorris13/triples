<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:paddingLeft="@dimen/stats_side_padding"
  android:paddingRight="@dimen/stats_side_padding"
  android:orientation="vertical">

  <TextView
    android:id="@+id/summary_title"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:singleLine="true"
    android:text="@string/summary"
    android:textColor="@color/color_separator"
    android:textStyle="bold"
    android:paddingTop="@dimen/stats_vert_padding"
    android:paddingBottom="@dimen/stats_vert_padding" />

  <View
    android:id="@+id/summary_divider"
    android:layout_width="fill_parent"
    android:layout_height="1dp"
    android:background="@color/color_separator" />

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="DISTRIBUTION"
    android:textStyle="bold"
    android:textSize="16sp"
    android:paddingTop="16dp" />

  <com.github.mikephil.charting.charts.BarChart
    android:id="@+id/histogram_chart"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp" />

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="TIME SERIES"
    android:textStyle="bold"
    android:textSize="16sp"
    android:paddingTop="16dp" />

  <com.github.mikephil.charting.charts.ScatterChart
    android:id="@+id/scatter_chart"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp" />

  <View
    android:layout_width="fill_parent"
    android:layout_height="1dp"
    android:background="@android:color/darker_gray" />

  <TableLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/stats_vert_padding"
    android:paddingBottom="@dimen/stats_vert_padding">

    <TableRow
      android:layout_width="wrap_content"
      android:layout_height="wrap_content">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingRight="5dp"
        android:text="@string/number_completed" />

      <TextView
        android:id="@+id/number_completed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    </TableRow>

    <TableRow
      android:layout_width="wrap_content"
      android:layout_height="wrap_content">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingRight="5dp"
        android:text="Most found:" />

      <TextView
        android:id="@+id/best"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    </TableRow>

    <TableRow
      android:layout_width="wrap_content"
      android:layout_height="wrap_content">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingRight="5dp"
        android:text="Average found:" />

      <TextView
        android:id="@+id/average"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    </TableRow>
  </TableLayout>

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="PERCENTILES"
    android:textStyle="bold"
    android:paddingTop="8dp" />

  <GridLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="4"
    android:paddingBottom="@dimen/stats_vert_padding">

    <TextView android:text="25th" android:paddingEnd="8dp" />
    <TextView android:text="50th" android:paddingEnd="8dp" />
    <TextView android:text="75th" android:paddingEnd="8dp" />
    <TextView android:text="95th" />

    <TextView android:id="@+id/p25" android:paddingEnd="8dp" />
    <TextView android:id="@+id/p50" android:paddingEnd="8dp" />
    <TextView android:id="@+id/p75" android:paddingEnd="8dp" />
    <TextView android:id="@+id/p95" />
  </GridLayout>

</LinearLayout>