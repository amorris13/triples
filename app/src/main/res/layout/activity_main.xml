<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Classic Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/classic_label"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/classic_resume_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/resume_game"
            android:visibility="gone" />

        <Button
            android:id="@+id/classic_new_game_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/new_game" />

        <Button
            android:id="@+id/classic_statistics_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/statistics" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/darker_gray" />

        <!-- Arcade Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/arcade_label"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/arcade_resume_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/resume_game"
            android:visibility="gone" />

        <Button
            android:id="@+id/arcade_new_game_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/new_game" />

        <Button
            android:id="@+id/arcade_statistics_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/statistics" />

    </LinearLayout>
</ScrollView>
