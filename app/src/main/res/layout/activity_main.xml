<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_background_main"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Classic Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/classic_container"
                style="@style/MainCardContainer"
                android:background="@color/classic_background">

                <TextView
                    style="@style/MainCardLabel"
                    android:text="@string/classic_label"
                    android:textColor="@color/classic_accent" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/classic_new_game_button"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/new_game"
                        android:theme="@style/ClassicButtonTheme" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/classic_split_button_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/classic_resume_button"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:text="@string/resume_game"
                            android:theme="@style/ClassicButtonTheme"
                            app:shapeAppearanceOverlay="@style/SplitButtonLeft" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/classic_dropdown_button"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:padding="0dp"
                            android:theme="@style/ClassicButtonTheme"
                            app:icon="@drawable/ic_expand_more"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:shapeAppearanceOverlay="@style/SplitButtonRight" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/classic_statistics_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/statistics"
                    android:textColor="@color/classic_accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Arcade Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/arcade_container"
                style="@style/MainCardContainer"
                android:background="@color/arcade_background">

                <TextView
                    style="@style/MainCardLabel"
                    android:text="@string/arcade_label"
                    android:textColor="@color/arcade_accent" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:id="@+id/arcade_new_game_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/arcade_new_game_fixed_button"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:text="Fixed"
                            android:theme="@style/ArcadeButtonTheme" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/arcade_new_game_bonus_button"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:text="Bonus"
                            android:theme="@style/ArcadeButtonTheme" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/arcade_split_button_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/arcade_resume_button"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:text="@string/resume_game"
                            android:theme="@style/ArcadeButtonTheme"
                            app:shapeAppearanceOverlay="@style/SplitButtonLeft" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/arcade_dropdown_button"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:padding="0dp"
                            android:theme="@style/ArcadeButtonTheme"
                            app:icon="@drawable/ic_expand_more"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:shapeAppearanceOverlay="@style/SplitButtonRight" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/arcade_statistics_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/statistics"
                    android:textColor="@color/arcade_accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Daily Puzzle Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/daily_container"
                style="@style/MainCardContainer"
                android:background="@color/daily_background">

                <TextView
                    style="@style/MainCardLabel"
                    android:text="@string/daily_label"
                    android:textColor="@color/daily_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/daily_play_button"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/play"
                    android:theme="@style/DailyButtonTheme" />

                <TextView
                    android:id="@+id/daily_completed_text"
                    style="@style/MainCardLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/completed"
                    android:textColor="@color/daily_accent"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/daily_statistics_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/statistics"
                    android:textColor="@color/daily_accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Zen Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/zen_container"
                style="@style/MainCardContainer"
                android:background="@color/zen_background">

                <TextView
                    style="@style/MainCardLabel"
                    android:text="@string/zen_label"
                    android:textColor="@color/zen_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/zen_button"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/play"
                    android:theme="@style/ZenButtonTheme" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
