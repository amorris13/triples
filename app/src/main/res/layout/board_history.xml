<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/toolbar" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Bottom panel: alternatives (found triple + placeholders) -->
        <LinearLayout
            android:id="@+id/bottom_inset_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <TextView
                android:id="@+id/alternatives_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBody2" />

            <com.antsapps.triples.views.FoundTriplesView
                android:id="@+id/found_triples_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Board: fills the rest of the space above the bottom panel -->
        <com.antsapps.triples.cardsview.CardsView
            android:id="@+id/cards_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/bottom_inset_container"
            android:layout_alignParentTop="true"
            android:clipChildren="false"
            android:clipToPadding="false" />

    </RelativeLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
