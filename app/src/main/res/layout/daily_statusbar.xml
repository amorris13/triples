<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_bar"
    style="@style/StatusBarContainer">

    <TextView
        android:id="@+id/triples_found_text"
        style="@style/status_bar_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true" />

    <TextView
        android:id="@+id/triples_found_key_text"
        style="@style/status_bar_key"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_below="@id/triples_found_text"
        android:text="@string/triples_found" />

    <TextView
        android:id="@+id/hint_used_text"
        style="@style/status_bar_key"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:text="@string/hint_used_indicator"
        android:textColor="@color/colorError"
        android:visibility="gone" />

    <TextView
        android:id="@+id/timer_value_text"
        style="@style/status_bar_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true" />

    <TextView
        android:id="@+id/timer_key_text"
        style="@style/status_bar_key"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_below="@id/timer_value_text"
        android:text="@string/time_elapsed" />

    <TextView
        android:id="@+id/daily_date_text"
        style="@style/status_bar_key"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:paddingBottom="4dp" />

</RelativeLayout>
