{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "sandbox": {
        "network": {
            "allowedDomains": [
                "dl.google.com",
                "plugins.gradle.org",
                "plugins-artifacts.gradle.org",
                "repo1.maven.org",
                "jitpack.io",
                "services.gradle.org"
            ]
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
                    }
                ]
            }
        ]
    }
}
